  <%= render Avo::Sidebar::LinkComponent.new label: 'Timesheets', path: main_app.avo_timesheets_path, active: :exclusive %>
</div>
<div class="pt-2 border-t border-gray-200 dark:border-gray-700">
  <div class="px-3 pt-2 text-sm font-semibold tracking-wide text-gray-500 uppercase dark:text-gray-400 flex items-center gap-2">
    <span class="inline-flex items-center justify-center w-7 h-7 text-gray-400 dark:text-gray-500">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path d="M4 3.5A1.5 1.5 0 0 1 5.5 2h6.379c.398 0 .78.158 1.06.44l2.621 2.621c.282.28.44.662.44 1.06V15.5A1.5 1.5 0 0 1 14.5 17h-9A1.5 1.5 0 0 1 4 15.5v-12Z" />
        <path d="M8.5 7a.75.75 0 0 0 0 1.5h3a.75.75 0 0 0 0-1.5h-3Zm-1 3.25A.75.75 0 0 1 8.25 9.5h3a.75.75 0 0 1 0 1.5h-3A.75.75 0 0 1 7.5 10.25Zm0 2.25A.75.75 0 0 1 8.25 11.5h1.5a.75.75 0 0 1 0 1.5h-1.5A.75.75 0 0 1 7.5 12.5Z" fill="currentColor" />
      </svg>
    </span>
    <span>Freshbooks</span>
  </div>
  <%= render Avo::Sidebar::LinkComponent.new(
        label: 'Freshbooks clients',
        path: "#{Avo.configuration.root_path}/resources/freshbooks_clients",
        active: :exclusive
      ) %>
  <%= render Avo::Sidebar::LinkComponent.new(
        label: 'Freshbooks invoices',
        path: "#{Avo.configuration.root_path}/resources/freshbooks_invoices",
        active: :exclusive
      ) %>
  <%= render Avo::Sidebar::LinkComponent.new(
        label: 'Freshbooks payments',
        path: "#{Avo.configuration.root_path}/resources/freshbooks_payments",
        active: :exclusive
      ) %>
  <%= render Avo::Sidebar::LinkComponent.new(
        label: 'Freshbooks tokens',
        path: "#{Avo.configuration.root_path}/resources/freshbooks_tokens",
        active: :exclusive
      ) %>
</div>
