<% content_for :title, "About Us - Bullet Services" %>

<%= render NavigationComponent.new(current_path: request.path) %>

<!-- About Hero Section -->
<section class="py-20 bg-white relative">
  <div class="container mx-auto px-6 max-w-4xl">
    <h1 class="text-5xl md:text-6xl font-light mb-8 text-gray-800">
      About us.
    </h1>
    <h2 class="text-3xl md:text-4xl font-light mb-12 text-gray-700">
      Our story and approach.
    </h2>
  </div>
</section>

<!-- About Content Section -->
<section class="py-12 bg-gray-50">
  <div class="container mx-auto px-6 max-w-4xl">
    <div class="prose prose-lg max-w-none text-gray-700 space-y-10">
      <section>
        <h2 class="text-2xl md:text-3xl font-light text-gray-900 mb-4">
          Who we are
        </h2>
        <p class="text-lg leading-relaxed">
          Bullet Services was founded in 2020 in the heart of London to focus on one thing:
          the careful restoration and protection of building exteriors. We blend traditional
          craftsmanship with modern methods to keep London’s architecture looking its best
          for years to come.
        </p>
      </section>

      <section>
        <h2 class="text-2xl md:text-3xl font-light text-gray-900 mb-4">
          How we work
        </h2>
        <p class="text-lg leading-relaxed mb-4">
          Our clients trust us to deliver complex exterior projects reliably and safely.
          We plan works around occupied buildings, communicate clearly, and stay focused
          on programme and budget.
        </p>
        <ul class="list-disc list-inside text-lg leading-relaxed space-y-1">
          <li>Dedicated project management from enquiry through to completion</li>
          <li>Skilled teams experienced in heritage and modern construction</li>
          <li>Clear scopes of work and transparent progress updates</li>
        </ul>
      </section>

      <section>
        <h2 class="text-2xl md:text-3xl font-light text-gray-900 mb-4">
          Why it matters
        </h2>
        <p class="text-lg leading-relaxed">
          Every façade we restore and every window we repair plays a part in preserving
          London’s architectural heritage. We see each project as a long-term investment
          in the buildings and communities we work with, and we bring that mindset to
          every detail on site.
        </p>
      </section>
    </div>
  </div>
</section>

<%= render FooterComponent.new %>
