<div id="hero-carousel" class="relative h-screen w-full overflow-hidden bg-black">
  <div class="relative h-full w-full">
    <div id="carousel-wrapper" class="flex h-full transition-transform duration-700 ease-in-out">
      <!-- Clone last slide for seamless loop -->
      <% last_slide = slides.last %>
      <div class="hero-slide flex-shrink-0 w-screen h-full" data-slide="clone-last">
        <div
          class="h-full w-full bg-cover bg-center bg-no-repeat"
          style="background-image: radial-gradient(circle at 100% 100%, transparent, rgb(0, 0, 0)), url('<%= asset_path(last_slide[:image]) %>'); background-position: 0px 0px, 50% 50%; background-size: auto, cover;"
        ></div>
      </div>

      <!-- Real slides -->
      <% slides.each_with_index do |slide, index| %>
        <div class="hero-slide flex-shrink-0 w-screen h-full" data-slide="<%= index %>">
          <div
            class="h-full w-full bg-cover bg-center bg-no-repeat"
            style="background-image: radial-gradient(circle at 100% 100%, transparent, rgb(0, 0, 0)), url('<%= asset_path(slide[:image]) %>'); background-position: 0px 0px, 50% 50%; background-size: auto, cover;"
          ></div>
        </div>
      <% end %>

      <!-- Clone first slide for seamless loop -->
      <% first_slide = slides.first %>
      <div class="hero-slide flex-shrink-0 w-screen h-full" data-slide="clone-first">
        <div
          class="h-full w-full bg-cover bg-center bg-no-repeat"
          style="background-image: radial-gradient(circle at 100% 100%, transparent, rgb(0, 0, 0)), url('<%= asset_path(first_slide[:image]) %>'); background-position: 0px 0px, 50% 50%; background-size: auto, cover;"
        ></div>
      </div>
    </div>
  </div>

  <!-- Fixed Text Overlay - Always visible -->
  <div class="absolute inset-0 flex items-center justify-center z-10">
    <div class="text-center px-6 max-w-4xl pointer-events-none">
      <h1 class="text-5xl md:text-7xl lg:text-8xl font-light text-white mb-6 leading-tight">
        <span class="static-text">We build</span><br>
        <span class="typewriter-container">
          <span class="typewriter-text" data-typewriter>exteriors.</span>
        </span>
      </h1>
      <p class="text-lg md:text-2xl text-gray-200 mb-10 max-w-2xl mx-auto">
        Specialists in façade restoration, window and stone repairs, and exterior maintenance
        for heritage and modern buildings.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 pointer-events-auto">
        <%= link_to "Request a quotation",
                    root_path(anchor: "contact"),
                    class: "inline-flex items-center justify-center px-8 py-3 rounded-lg bg-white text-black text-base md:text-lg font-semibold tracking-wide hover:bg-gray-100 transition-colors duration-200 shadow-lg shadow-black/30" %>
        <%= link_to "View our services",
                    services_path,
                    class: "inline-flex items-center justify-center px-8 py-3 rounded-lg bg-transparent border border-white/80 text-white text-base md:text-lg font-semibold tracking-wide hover:bg-white hover:text-black transition-colors duration-200" %>
      </div>
    </div>
  </div>

  <!-- Navigation Dots -->
  <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 flex space-x-3 z-20">
    <% slides.each_with_index do |_, index| %>
      <button
        type="button"
        data-dot="<%= index %>"
        class="carousel-dot w-3 h-3 rounded-full transition-all duration-300 <%= index == 0 ? 'bg-white' : 'bg-white/50' %> hover:bg-white/75 focus:outline-none pointer-events-auto"
        aria-label="Go to slide <%= index + 1 %>"
      ></button>
    <% end %>
  </div>
</div>
